# ==========================================
# Retrieval Infrastructure
# ==========================================

# Vector DB - Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Vector DB - PostgreSQL + pgvector
PGVECTOR_URI=postgresql://postgres:postgres@localhost:5433/vectors

# Embeddings - OpenAI (opzionale, se usato come provider)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==========================================
# Tracing / Observability - Arize Phoenix
# ==========================================
# Phoenix UI disponibile su http://localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_PROJECT_NAME=agent-setup
PHOENIX_TRACING_ENABLED=true

