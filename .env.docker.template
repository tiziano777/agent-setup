# ============================================
# Variabili d'ambiente per deploy Docker
# ============================================
#
# Copia questo file come .env.docker e compila i valori:
#   cp .env.docker.template .env.docker
#
# NOTA: Gli URL dei servizi (LITELLM_BASE_URL, QDRANT_URL, PGVECTOR_URI)
# sono gia' configurati nel docker-compose.prod.yml tramite la sezione
# 'environment'. NON servono qui. Qui vanno solo le API key e config.
#
# ============================================

# ==========================================
# API Key dei provider LLM
# ==========================================
# Compila almeno uno per far funzionare il proxy.
# I provider senza chiave verranno ignorati dal rotator.

# OpenRouter
OPENROUTER_API_KEY=

# Google AI Studio
GOOGLE_API_KEY=

# NVIDIA NIM
NVIDIA_API_KEY=

# Mistral
MISTRAL_API_KEY=
CODESTRAL_API_KEY=

# Vercel
VERCEL_API_KEY=

# OpenCode Zen
OPENCODEZEN_API_KEY=

# Cerebras
CEREBRAS_API_KEY=

# Groq
GROQ_API_KEY=

# Cohere
COHERE_API_KEY=

# GitHub Models
GITHUB_TOKEN=

# Cloudflare
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# ==========================================
# Embeddings (opzionale)
# ==========================================
# Necessario solo se usi OpenAI per gli embeddings.
# Se usi SentenceTransformer (locale), lascia vuoto.

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==========================================
# PostgreSQL (opzionale - override)
# ==========================================
# Cambia queste solo se vuoi credenziali diverse dal default.
# Default: postgres/postgres sul database 'vectors'

# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=vectors
